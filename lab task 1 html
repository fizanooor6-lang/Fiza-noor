<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>HTML5 Canvas Drawing App</title>

  <style>

    body{
      margin:0;
      padding:0;
      background:#111827;
      font-family:Arial, sans-serif;

      display:flex;
      justify-content:center;
      align-items:center;
      height:100vh;
    }

    .container{
      width:700px;
      background:#f3f3f3;
      padding:30px;
      border-radius:12px;
      text-align:center;
    }

    h1{
      font-size:32px;
      margin-bottom:20px;
      color:#333;
    }

    .tools{
      margin-bottom:20px;
    }

    label{
      font-size:18px;
      margin-right:10px;
    }

    input[type="color"]{
      width:40px;
      height:30px;
      border:none;
      cursor:pointer;
      vertical-align:middle;
    }

    button{
      padding:8px 18px;
      background:#2563eb;
      color:white;
      border:none;
      border-radius:4px;
      cursor:pointer;
      margin-left:10px;
    }

    button:hover{
      background:#1d4ed8;
    }

    canvas{
      border:2px solid gray;
      background:white;
      cursor:crosshair;
    }

  </style>
</head>

<body>

  <div class="container">

    <h1>HTML5 Canvas Drawing App</h1>

    <div class="tools">

      <label>Select Brush Color:</label>

      <input type="color" id="colorPicker" value="#000000">

      <button onclick="clearCanvas()">Clear Screen</button>

    </div>

    <canvas id="canvas" width="500" height="350"></canvas>

  </div>

  <script>

    const canvas = document.getElementById("canvas");
    const ctx = canvas.getContext("2d");

    const colorPicker = document.getElementById("colorPicker");

    let drawing = false;

    // Mouse Down
    canvas.addEventListener("mousedown", () => {
      drawing = true;
    });

    // Mouse Up
    canvas.addEventListener("mouseup", () => {
      drawing = false;
      ctx.beginPath();
    });

    // Mouse Move
    canvas.addEventListener("mousemove", draw);

    function draw(e){

      if(!drawing) return;

      ctx.lineWidth = 4;
      ctx.lineCap = "round";

      // Brush Color
      ctx.strokeStyle = colorPicker.value;

      ctx.lineTo(e.offsetX, e.offsetY);

      ctx.stroke();

      ctx.beginPath();

      ctx.moveTo(e.offsetX, e.offsetY);
    }

    // Clear Screen
    function clearCanvas(){

      ctx.clearRect(0, 0, canvas.width, canvas.height);

    }

  </script>

</body>
</html>
